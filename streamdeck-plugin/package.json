{
  "name": "com.duofilm.claude-monitor",
  "version": "1.0.0",
  "description": "Stream Deck plugin for monitoring Claude Code instances via MQTT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rollup -c && npm run deploy",
    "watch": "rollup -c -w",
    "deploy": "bash -c 'source ../windows/deploy-paths.sh && cp -r com.duofilm.claude-monitor.sdPlugin/bin com.duofilm.claude-monitor.sdPlugin/imgs com.duofilm.claude-monitor.sdPlugin/ui com.duofilm.claude-monitor.sdPlugin/manifest.json \"$DEPLOY_SD_PLUGIN/\"'"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.0.1",
    "mqtt": "^5.15.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "rollup": "^4.0.0",
    "tslib": "^2.6.0",
    "typescript": "^5.5.0"
  }
}
