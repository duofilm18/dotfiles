{
  "productName": "claude-overlay",
  "version": "0.1.0",
  "identifier": "com.duofilm.claude-overlay",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude Status",
        "width": 280,
        "height": 400,
        "decorations": true,
        "alwaysOnTop": true,
        "resizable": true,
        "transparent": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
