<?xml version="1.0"?>
<!DOCTYPE fontconfig SYSTEM "fonts.dtd">
<fontconfig>
  <dir>/mnt/c/Windows/Fonts</dir>

  <alias>
    <family>sans-serif</family>
    <prefer>
      <family>Microsoft JhengHei</family>
      <family>PMingLiU</family>
      <family>MingLiU</family>
      <family>sans-serif</family>
    </prefer>
  </alias>

  <alias>
    <family>serif</family>
    <prefer>
      <family>PMingLiU</family>
      <family>MingLiU</family>
      <family>serif</family>
    </prefer>
  </alias>

  <alias>
    <family>monospace</family>
    <prefer>
      <family>Microsoft JhengHei</family>
      <family>MingLiU</family>
      <family>monospace</family>
    </prefer>
  </alias>
</fontconfig>
