---
offline: true

skip_list:
  - args[module]
  - command-instead-of-module
  - ignore-errors
  - latest[git]
  - no-changed-when
  - package-latest
  - risky-file-permissions
  - risky-shell-pipe
  - var-naming[no-role-prefix]
  - yaml[empty-lines]
  - yaml[line-length]

exclude_paths:
  - .github/
  - scripts/
  - shared/
  - tests/
  - wsl/
